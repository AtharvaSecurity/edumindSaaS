generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN  SCHOOL_ADMIN  PRINCIPAL  TEACHER  ACCOUNTANT  STUDENT  PARENT
}

enum SubscriptionPlan { FREEMIUM  BASIC  PRO  ENTERPRISE }
enum SubscriptionStatus { ACTIVE  PAST_DUE  CANCELLED  TRIAL }
enum NotificationType { EMAIL  SMS  WHATSAPP  PUSH }
enum NotificationStatus { QUEUED  SENT  FAILED  READ }
enum AttendanceStatus { PRESENT  ABSENT  LATE  HALF_DAY  HOLIDAY }
enum LeaveStatus { PENDING  APPROVED  REJECTED  CANCELLED }
enum LeaveType { SICK  CASUAL  EMERGENCY  VACATION  OTHER }
enum FeeFrequency { MONTHLY  QUARTERLY  YEARLY  ONE_TIME }
enum PaymentMode { CASH  CHEQUE  UPI  NETBANKING  CARD }
enum PaymentStatus { PENDING  PARTIAL  PAID  OVERDUE  CANCELLED }
enum ExamType { UNIT_TEST  MID_TERM  HALF_YEARLY  ANNUAL  PRE_BOARD  BOARD }
enum GradeSystem { PERCENTAGE  CGPA  GRADES }

model Tenant {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @db.VarChar(255)
  subdomain          String             @unique @db.VarChar(100)
  address            String?            @db.Text
  city               String             @db.VarChar(100)
  state              String             @db.VarChar(100)
  pincode            String?            @db.VarChar(10)
  phone              String?            @db.VarChar(15)
  email              String?            @db.VarChar(255)
  logoUrl            String?            @db.Text @map("logo_url")
  subscriptionPlan   SubscriptionPlan   @default(FREEMIUM) @map("subscription_plan")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionExpiry DateTime?          @db.Timestamptz() @map("subscription_expiry")
  settings           Json?              @db.JsonB
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt          DateTime           @updatedAt @db.Timestamptz() @map("updated_at")
  users              User[]
  admins             Admin[]
  teachers           Teacher[]
  students           Student[]
  parents            Parent[]
  classes            Class[]
  sections           Section[]
  academicYears      AcademicYear[]
  subjects           Subject[]
  attendances        Attendance[]
  leaves             Leave[]
  feeStructures      FeeStructure[]
  studentFees        StudentFee[]
  payments           Payment[]
  exams              Exam[]
  results            Result[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  @@map("tenants")
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid @map("tenant_id")
  email           String?        @unique @db.VarChar(255)
  phone           String?        @unique @db.VarChar(15)
  passwordHash    String         @map("password_hash") @db.VarChar(255)
  role            UserRole
  isActive        Boolean        @default(true) @map("is_active")
  lastLogin       DateTime?      @db.Timestamptz() @map("last_login")
  refreshToken    String?        @map("refresh_token") @db.VarChar(500)
  createdAt       DateTime       @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt       DateTime       @updatedAt @db.Timestamptz() @map("updated_at")
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admin           Admin?
  teacher         Teacher?
  student         Student?
  parent          Parent?
  attendances     Attendance[]
  leaves          Leave[]        @relation("LeaveRequester")
  approvedLeaves  Leave[]        @relation("LeaveApprover")
  payments        Payment[]
  results         Result[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  @@index([tenantId, email])
  @@map("users")
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid @map("user_id")
  tenantId     String   @db.Uuid @map("tenant_id")
  fullName     String   @map("full_name") @db.VarChar(255)
  employeeCode String?  @map("employee_code") @db.VarChar(50)
  phone        String?  @db.VarChar(15)
  createdAt    DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt    DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@map("admins")
}

model Teacher {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @db.Uuid @map("user_id")
  tenantId       String    @db.Uuid @map("tenant_id")
  fullName       String    @map("full_name") @db.VarChar(255)
  employeeCode   String?   @map("employee_code") @db.VarChar(50)
  qualification  String?   @db.VarChar(255)
  specialization String?   @db.VarChar(255)
  dateOfJoining  DateTime? @db.Date @map("date_of_joining")
  phone          String?   @db.VarChar(15)
  address        String?   @db.Text
  createdAt      DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime  @updatedAt @db.Timestamptz() @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjects       TeacherSubject[]
  @@map("teachers")
}

model Student {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @unique @db.Uuid @map("user_id")
  tenantId       String           @db.Uuid @map("tenant_id")
  admissionId    String           @unique @map("admission_id") @db.VarChar(50)
  rollNumber     Int?             @map("roll_number")
  fullName       String           @map("full_name") @db.VarChar(255)
  dob            DateTime?        @db.Date
  gender         String?          @db.Char(1)
  bloodGroup     String?          @map("blood_group") @db.VarChar(5)
  address        String?          @db.Text
  admissionDate  DateTime?        @db.Date @map("admission_date")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime         @updatedAt @db.Timestamptz() @map("updated_at")
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentStudents ParentStudent[]
  attendances    Attendance[]
  leaves         Leave[]
  studentFees    StudentFee[]
  results        Result[]
  @@map("students")
}

model Parent {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @db.Uuid @map("user_id")
  tenantId       String         @db.Uuid @map("tenant_id")
  fullName       String         @map("full_name") @db.VarChar(255)
  occupation     String?        @db.VarChar(100)
  phoneSecondary String?        @map("phone_secondary") @db.VarChar(15)
  relation       String         @db.VarChar(20)
  createdAt      DateTime       @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime       @updatedAt @db.Timestamptz() @map("updated_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentStudents ParentStudent[]
  @@map("parents")
}

model ParentStudent {
  parentId     String   @db.Uuid @map("parent_id")
  studentId    String   @db.Uuid @map("student_id")
  relationship String?  @db.VarChar(50)
  createdAt    DateTime @default(now()) @db.Timestamptz() @map("created_at")
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@id([parentId, studentId])
  @@map("parent_students")
}

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  name      String   @db.VarChar(9)
  startDate DateTime @db.Date @map("start_date")
  endDate   DateTime @db.Date @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, name])
  @@map("academic_years")
}

model Class {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @db.Uuid @map("tenant_id")
  name              String    @db.VarChar(50)
  numericIdentifier Int?      @map("numeric_identifier")
  createdAt         DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt         DateTime  @updatedAt @db.Timestamptz() @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections          Section[]
  subjects          Subject[]
  @@unique([tenantId, name])
  @@map("classes")
}

model Section {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid @map("tenant_id")
  classId        String       @db.Uuid @map("class_id")
  name           String       @db.VarChar(10)
  classTeacherId String?      @db.Uuid @map("class_teacher_id")
  createdAt      DateTime     @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime     @updatedAt @db.Timestamptz() @map("updated_at")
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendances    Attendance[]
  @@unique([classId, name])
  @@map("sections")
}

model Subject {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid @map("tenant_id")
  classId   String           @db.Uuid @map("class_id")
  name      String           @db.VarChar(100)
  code      String?          @db.VarChar(20)
  maxMarks  Int              @default(100) @map("max_marks")
  createdAt DateTime         @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime         @updatedAt @db.Timestamptz() @map("updated_at")
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  teachers  TeacherSubject[]
  results   Result[]
  @@unique([classId, name])
  @@map("subjects")
}

model TeacherSubject {
  teacherId String  @db.Uuid @map("teacher_id")
  subjectId String  @db.Uuid @map("subject_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  @@id([teacherId, subjectId])
  @@map("teacher_subjects")
}

model Attendance {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @db.Uuid @map("tenant_id")
  studentId  String           @db.Uuid @map("student_id")
  sectionId  String?          @db.Uuid @map("section_id")
  date       DateTime         @db.Date
  status     AttendanceStatus
  markedBy   String           @db.Uuid @map("marked_by")
  remark     String?          @db.VarChar(500)
  createdAt  DateTime         @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt  DateTime         @updatedAt @db.Timestamptz() @map("updated_at")
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section    Section?         @relation(fields: [sectionId], references: [id])
  user       User             @relation(fields: [markedBy], references: [id])
  @@unique([studentId, date])
  @@map("attendances")
}

model Leave {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @db.Uuid @map("tenant_id")
  studentId  String?     @db.Uuid @map("student_id")
  userId     String      @db.Uuid @map("user_id")
  leaveType  LeaveType   @map("leave_type")
  startDate  DateTime    @db.Date @map("start_date")
  endDate    DateTime    @db.Date @map("end_date")
  reason     String      @db.Text
  status     LeaveStatus @default(PENDING)
  approvedBy String?     @db.Uuid @map("approved_by")
  approvedAt DateTime?   @db.Timestamptz() @map("approved_at")
  remark     String?     @db.VarChar(500)
  createdAt  DateTime    @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt  DateTime    @updatedAt @db.Timestamptz() @map("updated_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student    Student?    @relation(fields: [studentId], references: [id])
  user       User        @relation("LeaveRequester", fields: [userId], references: [id])
  approver   User?       @relation("LeaveApprover", fields: [approvedBy], references: [id])
  @@map("leaves")
}

model FeeStructure {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid @map("tenant_id")
  name        String       @db.VarChar(100)
  description String?      @db.Text
  amount      Decimal      @db.Decimal(10, 2)
  frequency   FeeFrequency
  classId     String?      @db.Uuid @map("class_id")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime     @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentFees StudentFee[]
  @@map("fee_structures")
}

model StudentFee {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid @map("tenant_id")
  studentId       String        @db.Uuid @map("student_id")
  feeStructureId  String        @db.Uuid @map("fee_structure_id")
  academicYear    String        @map("academic_year") @db.VarChar(9)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  dueDate         DateTime      @db.Date @map("due_date")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz() @map("updated_at")
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure  @relation(fields: [feeStructureId], references: [id])
  payments        Payment[]
  @@map("student_fees")
}

model Payment {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid @map("tenant_id")
  studentFeeId    String      @db.Uuid @map("student_fee_id")
  amount          Decimal     @db.Decimal(10, 2)
  paymentMode     PaymentMode @map("payment_mode")
  transactionRef  String?     @map("transaction_ref") @db.VarChar(100)
  paymentDate     DateTime    @default(now()) @db.Date @map("payment_date")
  collectedBy     String      @db.Uuid @map("collected_by")
  receiptNumber   String      @unique @map("receipt_number") @db.VarChar(50)
  remark          String?     @db.VarChar(500)
  createdAt       DateTime    @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt       DateTime    @updatedAt @db.Timestamptz() @map("updated_at")
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentFee      StudentFee  @relation(fields: [studentFeeId], references: [id])
  collector       User        @relation(fields: [collectedBy], references: [id])
  @@map("payments")
}

model Exam {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid @map("tenant_id")
  name       String    @db.VarChar(100)
  type       ExamType
  classId    String    @db.Uuid @map("class_id")
  startDate  DateTime  @db.Date @map("start_date")
  endDate    DateTime  @db.Date @map("end_date")
  maxMarks   Int       @default(100) @map("max_marks")
  passMarks  Int       @default(33) @map("pass_marks")
  createdAt  DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt  DateTime  @updatedAt @db.Timestamptz() @map("updated_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results    Result[]
  @@map("exams")
}

model Result {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid @map("tenant_id")
  examId     String   @db.Uuid @map("exam_id")
  studentId  String   @db.Uuid @map("student_id")
  subjectId  String   @db.Uuid @map("subject_id")
  marks      Int
  grade      String?  @db.VarChar(5)
  remarks    String?  @db.VarChar(500)
  enteredBy  String   @db.Uuid @map("entered_by")
  createdAt  DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt  DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id])
  user       User     @relation(fields: [enteredBy], references: [id])
  @@unique([examId, studentId, subjectId])
  @@map("results")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid @map("tenant_id")
  userId     String   @db.Uuid @map("user_id")
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values") @db.JsonB
  newValues  Json?    @map("new_values") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz() @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("audit_logs")
}

model Notification {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @db.Uuid @map("tenant_id")
  recipientUserId String             @db.Uuid @map("recipient_user_id")
  type            NotificationType
  status          NotificationStatus @default(QUEUED)
  templateId      String?            @map("template_id") @db.VarChar(50)
  payload         Json?              @db.JsonB
  sentAt          DateTime?          @db.Timestamptz() @map("sent_at")
  createdAt       DateTime           @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt       DateTime           @updatedAt @db.Timestamptz() @map("updated_at")
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  @@map("notifications")
}

model Timetable {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid @map("tenant_id")
  classId    String    @db.Uuid @map("class_id")
  sectionId  String    @db.Uuid @map("section_id")
  subjectId  String    @db.Uuid @map("subject_id")
  teacherId  String    @db.Uuid @map("teacher_id")
  dayOfWeek  Int       @map("day_of_week")
  startTime  String    @map("start_time") @db.VarChar(5)
  endTime    String    @map("end_time") @db.VarChar(5)
  roomNo     String?   @map("room_no") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt  DateTime  @updatedAt @db.Timestamptz() @map("updated_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class      Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  section    Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject    Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  @@unique([sectionId, dayOfWeek, startTime])
  @@map("timetables")
}

model Syllabus {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  classId     String   @db.Uuid @map("class_id")
  subjectId   String   @db.Uuid @map("subject_id")
  topic       String   @db.VarChar(255)
  description String?  @db.Text
  month       String   @db.VarChar(7)
  status      String   @default("PENDING") @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  @@map("syllabi")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  eventDate   DateTime @db.Date @map("event_date")
  eventType   String   @default("GENERAL") @db.VarChar(30)
  createdAt   DateTime @default(now()) @db.Timestamptz() @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@map("events")
}

model Book {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  title       String   @db.VarChar(255)
  author      String   @db.VarChar(255)
  isbn        String?  @db.VarChar(20)
  category    String   @default("GENERAL") @db.VarChar(50)
  quantity    Int      @default(1)
  available   Int      @default(1)
  shelfNo     String?  @map("shelf_no") @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issues      BookIssue[]
  @@map("books")
}

model BookIssue {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid @map("tenant_id")
  bookId      String    @db.Uuid @map("book_id")
  studentId   String    @db.Uuid @map("student_id")
  issueDate   DateTime  @default(now()) @db.Date @map("issue_date")
  dueDate     DateTime  @db.Date @map("due_date")
  returnDate  DateTime? @db.Date @map("return_date")
  status      String    @default("ISSUED") @db.VarChar(20)
  fine        Decimal   @default(0) @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime  @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@map("book_issues")
}

model Transport {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  routeName   String   @map("route_name") @db.VarChar(100)
  vehicleNo   String   @map("vehicle_no") @db.VarChar(20)
  driverName  String   @map("driver_name") @db.VarChar(255)
  driverPhone String   @map("driver_phone") @db.VarChar(15)
  capacity    Int      @default(40)
  fee         Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students    TransportStudent[]
  stops       RouteStop[]
  @@map("transports")
}

model RouteStop {
  id          String    @id @default(uuid()) @db.Uuid
  transportId String    @db.Uuid @map("transport_id")
  stopName    String    @map("stop_name") @db.VarChar(255)
  stopOrder   Int       @map("stop_order")
  pickupTime  String    @map("pickup_time") @db.VarChar(5)
  dropTime    String    @map("drop_time") @db.VarChar(5)
  createdAt   DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  @@map("route_stops")
}

model TransportStudent {
  id          String    @id @default(uuid()) @db.Uuid
  transportId String    @db.Uuid @map("transport_id")
  studentId   String    @db.Uuid @map("student_id")
  stopId      String?   @db.Uuid @map("stop_id")
  createdAt   DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  stop        RouteStop? @relation(fields: [stopId], references: [id])
  @@unique([transportId, studentId])
  @@map("transport_students")
}

model StaffSalary {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  teacherId   String   @db.Uuid @map("teacher_id")
  month       String   @db.VarChar(7)
  basicPay    Decimal  @map("basic_pay") @db.Decimal(10, 2)
  deductions  Decimal  @default(0) @db.Decimal(10, 2)
  bonus       Decimal  @default(0) @db.Decimal(10, 2)
  netPay      Decimal  @map("net_pay") @db.Decimal(10, 2)
  status      String   @default("PENDING") @db.VarChar(20)
  paidDate    DateTime? @db.Date @map("paid_date")
  createdAt   DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz() @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  @@unique([teacherId, month])
  @@map("staff_salaries")
}

model Notice {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  title     String   @db.VarChar(255)
  content   String   @db.Text
  priority  String   @default("NORMAL") @db.VarChar(20)
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@map("notices")
}
